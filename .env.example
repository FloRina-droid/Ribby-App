# Copy to .env before first public start.
RIBBY_PUBLIC_URL=https://ribby.example.org
RIBBY_ADMIN_EMAIL=admin@example.org

# Set a strong first password before first start.
# Change it in the app immediately after login.
RIBBY_ADMIN_PASSWORD=CHANGE_ME_USE_A_LONG_RANDOM_PASSWORD

RIBBY_HOST=0.0.0.0
RIBBY_PORT=7432
RIBBY_DATA_DIR=/data/ribby_data
RIBBY_MAX_UPLOAD_MB=80

# Same-origin deployments can leave this empty.
# If frontend and API are split across domains, set comma-separated origins.
RIBBY_CORS_ORIGINS=
